{
  "name": "moyens-generaux-app",
  "version": "1.0.0",
  "description": "Gestion Bons de Commande & Inventaire — Moyens Généraux",
  "main": "electron/main.js",
  "author": "Hyazid",
  "scripts": {
    "dev:react":    "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k -s first \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:react":  "vite build",
    "build":        "npm run build:react && electron-builder --linux --win",
    "build:linux":  "npm run build:react && electron-builder --linux",
    "build:win":    "npm run build:react && electron-builder --win",
    "rebuild":      "electron-rebuild -f -w better-sqlite3",
    "postinstall":  "electron-builder install-app-deps"
  },
  "build": {
    "appId": "dz.entreprise.moyens-generaux",
    "productName": "Moyens Generaux",
    "copyright": "Copyright © 2025 Hyazid",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Moyens Generaux",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "electron": "^22.3.27",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^4.5.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.0",
    "@heroicons/react": "^2.0.0",
    "@hookform/resolvers": "^3.3.0",
    "@tanstack/react-table": "^8.10.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.4.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "jspdf": "^2.5.0",
    "jspdf-autotable": "^3.8.0",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-hot-toast": "^2.4.0",
    "react-router-dom": "^6.20.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  }
}